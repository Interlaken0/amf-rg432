{
  "name": "rg432-test-rig",
  "version": "0.0.0",
  "description": "Windows desktop test rig for programming and verifying RG432 audio conversion boards",
  "type": "module",
  "author": "Greg",
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "npx @electron/rebuild -w better-sqlite3 koffi && vite",
    "build": "tsc && vite build && npm run copy-migrations && electron-builder",
    "build:win": "tsc && vite build && npm run copy-migrations && electron-builder --win",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "rebuild:node": "npx @electron/rebuild -w better-sqlite3 koffi",
    "copy-migrations": "xcopy \"src\\main\\migrations\" \"dist\\main\\migrations\" /E /I /Y",
    "test": "npm rebuild better-sqlite3 koffi && vitest run",
    "test:watch": "vitest",
    "test:changed": "npm rebuild better-sqlite3 koffi && vitest run --changed",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps && npx @electron/rebuild --version=35.7.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "koffi": "^2.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^9.20.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "commit-and-tag-version": "^12.5.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.15.0",
    "husky": "^9.1.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^3.0.0"
  }
}
